{
  "name": "fumika-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core",
    "dev:ide": "npm run dev -w packages/ide",
    "dev:playground": "npm run dev -w packages/playground",
    "example:build": "npm run build -w packages/playground",
    "example:dev": "npm run dev -w packages/playground",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}