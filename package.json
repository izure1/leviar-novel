{
  "name": "sori",
  "version": "0.0.1",
  "description": "A powerful and flexible modular visual novel engine based on web technologies.",
  "license": "MIT",
  "author": "izure <admin@izure.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izure1/sori.git"
  },
  "bugs": {
    "url": "https://github.com/izure1/sori/issues"
  },
  "homepage": "https://github.com/izure1/sori#readme",
  "keywords": [
    "visual-novel",
    "engine",
    "canvas",
    "typescript",
    "modular",
    "leviar"
  ],
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "node build/index.js && tsc -p tsconfig.build.json",
    "example:build": "esbuild example/main.ts --bundle --outfile=example/bundle.js --platform=browser --target=esnext --sourcemap",
    "example:dev": "esbuild example/main.ts --bundle --outfile=example/bundle.js --platform=browser --target=esnext --sourcemap --watch"
  },
  "devDependencies": {
    "animalese-tts": "^1.1.3",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "hookall": "^2.2.0",
    "leviar": "^1.0.8"
  }
}